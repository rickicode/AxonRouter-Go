{
  "mcpServers": {
    "basic-memory": {
      "type": "stdio",
      "command": "basic-memory",
      "args": [
        "mcp",
        "--project",
        "axonrouter-go"
      ],
      "disabled": false,
      "directTools": true
    },
    "openlore": {
      "command": "npx",
      "args": [
        "--yes",
        "openlore",
        "mcp",
        "--preset",
        "substrate"
      ]
    }
  }
}
